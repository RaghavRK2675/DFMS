# ====== DFMS frontend env vars ======

# Where the Node API is running.
# Local dev:                   http://localhost:4000
# Render production example:   https://dfms-api.onrender.com
VITE_API_URL=http://localhost:4000

# Google OAuth client ID (from https://console.cloud.google.com/apis/credentials)
# Authorized JavaScript origins must include http://localhost:8080 (dev)
# and https://raghavrk2675.github.io (GH Pages).
VITE_GOOGLE_CLIENT_ID=

# Only used by the GitHub Pages build (set automatically by the workflow).
# Leave unset for Lovable preview and local dev.
# VITE_BASE_PATH=/DFMS/
