# ====== DFMS API — required env vars ======
PORT=4000
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/dfms?retryWrites=true&w=majority

# JWT signing secret — generate with:  openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include your frontend URL
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://raghavrk2675.github.io

# Auto-seed demo data + simulate live sensor jitter every 30s
ENABLE_SEED=true
ENABLE_LIVE_SIMULATION=true
